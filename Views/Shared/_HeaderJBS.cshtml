@* Cabeçalho corporativo JBS Aulas — compartilhado entre Index e Watch *@
<header class="h-16 bg-[#2E2F86] flex items-center justify-between px-8 z-20 shrink-0 shadow-lg">

    <!-- Logo / Identidade -->
    <div class="flex items-center gap-10">
        <a asp-controller="Home" asp-action="Index" class="leading-none">
            <span class="font-black text-white text-xl tracking-tighter uppercase">
                JBS <span class="text-[#46C1E6]">AULAS</span>
            </span>
        </a>
    </div>

    <!-- Campo de busca -->
    <div class="flex-1 max-w-lg px-5 hidden md:block">
        <div class="relative">
            <input type="text"
                   placeholder="O que você deseja?"
                   class="w-full bg-white/10 border border-white/20 text-white rounded-sm py-2 pl-4 pr-10
                          focus:outline-none focus:border-[#46C1E6] transition-all text-sm placeholder-white/50" />
            <i data-lucide="search" class="absolute right-3 top-1/2 -translate-y-1/2 text-white/60 w-4 h-4"></i>
        </div>
    </div>

</header>
