@{ Layout = null; }
<!DOCTYPE html>
<html lang="pt-br">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>JBS COUROS AULAS</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;700;900&display=swap" rel="stylesheet">
    <script src="https://cdn.tailwindcss.com"></script>
    <script src="https://unpkg.com/lucide@latest"></script>
    <style>
        body { font-family: 'Inter', sans-serif; }

        .custom-scrollbar::-webkit-scrollbar { width: 6px; }
        .custom-scrollbar::-webkit-scrollbar-track { background: #F4F4F4; }
        .custom-scrollbar::-webkit-scrollbar-thumb { background: #E0E0E0; }
        .custom-scrollbar::-webkit-scrollbar-thumb:hover { background: #D61F26; }

        .line-clamp-2 {
            display: -webkit-box;
            -webkit-line-clamp: 2;
            -webkit-box-orient: vertical;
            overflow: hidden;
        }

        #player-overlay { transition: opacity 0.3s ease; }
    </style>
</head>
<body class="bg-[#F9F9F9] text-[#333333]">
    <div class="flex flex-col min-h-screen">

        <!-- Header -->
        <header class="h-16 bg-white border-b-4 border-[#D61F26] flex items-center justify-between px-8 z-20 shrink-0 shadow-sm sticky top-0">
            <div class="flex items-center gap-6">
                <a href="/Home/Index" class="flex items-center gap-2 group" title="Voltar para o início">
                    <i data-lucide="arrow-left" class="w-4 h-4 text-gray-400 group-hover:text-[#D61F26] transition-colors"></i>
                </a>
                <div class="flex items-center gap-2">
                    <div class="flex flex-col">
                        <span class="font-black text-[#333333] text-xl tracking-tighter leading-none uppercase">
                            JBS <span class="text-[#D61F26]">COUROS</span>
                        </span>
                        <span class="text-[9px] text-gray-400 font-bold tracking-widest uppercase">Portal de Comunicação Interna</span>
                    </div>
                </div>
            </div>

            <div class="flex-1 max-w-lg px-5 hidden md:block">
                <div class="relative">
                    <input type="text" placeholder="O que você deseja?"
                           class="w-full bg-[#F4F4F4] border border-[#E0E0E0] rounded-sm py-2 pl-4 pr-10 focus:outline-none focus:border-[#D61F26] transition-all text-sm placeholder-gray-400" />
                    <i data-lucide="search" class="absolute right-3 top-1/2 -translate-y-1/2 text-gray-400 w-4 h-4"></i>
                </div>
            </div>
        </header>

        <!-- Main Content -->
        <main class="flex-1 custom-scrollbar">
            <div class="max-w-5xl mx-auto px-4 md:px-8 py-8">

                <!-- Player -->
                <div id="player-container" class="relative w-full aspect-video bg-black rounded-sm overflow-hidden shadow-2xl mb-0">
                    <img id="player-thumb" src="" alt="Thumbnail do vídeo" class="w-full h-full object-cover opacity-80" />
                    <div id="player-overlay" class="absolute inset-0 flex flex-col items-center justify-center bg-black/50 cursor-pointer" onclick="startVideo()">
                        <div class="w-20 h-20 bg-[#D61F26] rounded-full flex items-center justify-center shadow-2xl hover:bg-[#b81a20] transition-colors mb-5">
                            <i data-lucide="play" class="text-white fill-white w-9 h-9 ml-1"></i>
                        </div>
                        <span class="text-white text-[11px] font-black tracking-[0.3em] uppercase">Clique para iniciar</span>
                    </div>
                    <div id="player-active" class="absolute inset-0 hidden items-center justify-center bg-black">
                        <p class="text-white text-sm font-bold tracking-widest uppercase opacity-50">Reprodução simulada</p>
                    </div>
                </div>

                <!-- Video Info -->
                <div class="bg-white border border-[#E0E0E0] border-t-0 rounded-b-sm px-6 py-6 mb-8">
                    <div class="flex items-center gap-4 mb-4">
                        <span id="video-category" class="bg-[#D61F26] text-white text-[10px] font-black px-3 py-1 uppercase tracking-wider"></span>
                        <span id="video-date" class="text-[11px] font-bold text-gray-400 uppercase tracking-widest"></span>
                    </div>

                    <h1 id="video-title" class="text-3xl md:text-4xl font-black text-[#333333] uppercase italic tracking-tighter leading-tight mb-4"></h1>

                    <p id="video-description" class="text-[#5B7FA6] text-sm leading-relaxed mb-6"></p>
                </div>

                <!-- Sugestões -->
                <div class="mb-12">
                    <div class="flex items-center gap-3 mb-1">
                        <div class="w-1 h-6 bg-[#D61F26]"></div>
                        <h2 class="text-lg font-black text-[#333333] uppercase tracking-tighter italic">Sugestões</h2>
                    </div>
                    <div class="w-full h-[3px] bg-[#D61F26] mb-6"></div>

                    <div id="suggestions-list" class="flex flex-col gap-4"></div>
                </div>

                <!-- Footer -->
                <footer class="py-10 border-t border-[#E0E0E0] flex flex-col md:flex-row justify-between items-center gap-6 text-[10px] font-bold text-gray-400 uppercase tracking-[0.3em]">
                    <span>© 2024 JBS S.A. • Portal de Comunicação</span>
                    <div class="flex gap-10">
                        <a href="#" class="hover:text-[#D61F26] transition-colors">Suporte TI</a>
                        <a href="#" class="hover:text-[#D61F26] transition-colors">Segurança</a>
                    </div>
                </footer>
            </div>
        </main>
    </div>

    <script>
        // ─── Catálogo de vídeos ───────────────────────────────────────────────────
        // Para adicionar mais vídeos no futuro, basta incluir um novo objeto neste array.
        const videos = [
            {
                id: 1,
                title: 'Treinamento de Segurança Operacional - Planta Lins',
                duration: '45:20',
                thumbnail: 'https://images.unsplash.com/photo-1581092160562-40aa08e78837?auto=format&fit=crop&w=1200',
                category: 'Treinamentos',
                date: 'Há 2 dias',
                description: 'Instruções completas sobre o uso de EPIs e operação de maquinário pesado. Este treinamento cobre todos os protocolos de segurança exigidos pela norma NR-12 para colaboradores da Planta Lins.'
            },
            {
                id: 2,
                title: 'Workshop de Sustentabilidade e ESG 2024',
                duration: '1:12:05',
                thumbnail: 'https://images.unsplash.com/photo-1542601906990-b4d3fb773b09?auto=format&fit=crop&w=1200',
                category: 'Eventos',
                date: 'Há 1 semana',
                description: 'Workshop completo sobre as metas ESG da JBS para 2024, com apresentação dos resultados ambientais, sociais e de governança do último trimestre.'
            },
            {
                id: 3,
                title: 'Mensagem do CEO - Resultados Globais Q3',
                duration: '58:00',
                thumbnail: 'https://images.unsplash.com/photo-1556761175-b413da4baf72?auto=format&fit=crop&w=1200',
                category: 'Reuniões',
                date: 'Há 3 dias',
                description: 'Mensagem direta do CEO para todos os colaboradores com os destaques dos resultados globais do terceiro trimestre e as perspectivas para o próximo período.'
            },
            {
                id: 4,
                title: 'Boas Práticas de Fabricação (BPF)',
                duration: '12:15',
                thumbnail: 'https://images.unsplash.com/photo-1566933267003-31119463286d?auto=format&fit=crop&w=1200',
                category: 'Compliance',
                date: 'Ontem',
                description: 'Guia prático sobre as Boas Práticas de Fabricação obrigatórias para todas as linhas de produção. Conteúdo atualizado conforme as normas vigentes de segurança alimentar.'
            },
            {
                id: 5,
                title: 'Manual do Novo Colaborador - Administrativo',
                duration: '08:45',
                thumbnail: 'https://images.unsplash.com/photo-1454165833767-027ffea9e77b?auto=format&fit=crop&w=1200',
                category: 'Treinamentos',
                date: 'Há 1 mês',
                description: 'Onboarding completo para novos colaboradores da área administrativa: cultura organizacional, benefícios, sistemas internos e fluxos de trabalho.'
            },
            {
                id: 6,
                title: 'Planejamento Logístico para 2025',
                duration: '2:30:00',
                thumbnail: 'https://images.unsplash.com/photo-1586528116311-ad8dd3c8310d?auto=format&fit=crop&w=1200',
                category: 'Reuniões',
                date: 'Há 5 dias',
                description: 'Reunião de planejamento estratégico com as equipes de logística para definição de rotas, parceiros e metas de entrega para o ano de 2025.'
            },
            {
                id: 7,
                title: 'Integração: Valores e Cultura Alimentar',
                duration: '15:30',
                thumbnail: 'https://images.unsplash.com/photo-1517048676732-d65bc937f952?auto=format&fit=crop&w=1200',
                category: 'Treinamentos',
                date: 'Há 2 semanas',
                description: 'Apresentação dos valores fundamentais da JBS, missão, visão e os compromissos com a cadeia alimentar sustentável e responsável.'
            },
            {
                id: 8,
                title: 'Inovação na Cadeia de Suprimentos',
                duration: '34:10',
                thumbnail: 'https://images.unsplash.com/photo-1565610222536-ef125c59da2e?auto=format&fit=crop&w=1200',
                category: 'Treinamentos',
                date: 'Há 4 dias',
                description: 'Case de inovação aplicada à cadeia de suprimentos da JBS, com uso de tecnologia para rastreamento, eficiência operacional e redução de desperdício.'
            },
        ];

        // ─── Leitura de parâmetros da URL ────────────────────────────────────────
        const params = new URLSearchParams(window.location.search);
        const currentId = parseInt(params.get('id')) || 1;
        const current = videos.find(v => v.id === currentId) || videos[0];

        // ─── Renderiza vídeo atual ────────────────────────────────────────────────
        document.getElementById('player-thumb').src = current.thumbnail;
        document.getElementById('player-thumb').alt = current.title;
        document.getElementById('video-category').textContent = current.category;
        document.getElementById('video-date').textContent = current.date;
        document.getElementById('video-title').textContent = current.title;
        document.getElementById('video-description').textContent = current.description;
        document.title = 'JBS COUROS - ' + current.title;

        // ─── Renderiza sugestões (primeiros 2 vídeos diferentes do atual) ────────
        const suggestions = videos.filter(v => v.id !== current.id).slice(0, 2);
        const suggestionsList = document.getElementById('suggestions-list');

        suggestions.forEach(v => {
            const card = document.createElement('a');
            card.href = '/Home/Watch?id=' + v.id;
            card.className = 'group flex gap-4 bg-white border border-[#E0E0E0] hover:border-[#D61F26] rounded-sm overflow-hidden shadow-sm hover:shadow-lg transition-all cursor-pointer';
            card.innerHTML = `
                <div class="relative w-44 md:w-56 shrink-0 aspect-video overflow-hidden bg-black">
                    <img src="${v.thumbnail}" alt="${v.title}" class="w-full h-full object-cover opacity-90 group-hover:opacity-100 group-hover:scale-105 transition-all duration-500" />
                    <span class="absolute bottom-1.5 right-1.5 bg-[#D61F26] text-white px-1.5 py-0.5 rounded-sm text-[9px] font-black">${v.duration}</span>
                    <div class="absolute inset-0 flex items-center justify-center opacity-0 group-hover:opacity-100 transition-opacity bg-black/40">
                        <div class="w-9 h-9 bg-[#D61F26] rounded-full flex items-center justify-center shadow-xl">
                            <i data-lucide="play" class="text-white fill-white w-4 h-4 ml-0.5"></i>
                        </div>
                    </div>
                </div>
                <div class="flex flex-col justify-center py-4 pr-4 gap-2">
                    <span class="text-[9px] font-black text-[#D61F26] uppercase tracking-[0.2em]">${v.category}</span>
                    <h3 class="font-bold text-sm text-[#333333] group-hover:text-[#D61F26] transition-colors uppercase tracking-tight leading-tight line-clamp-2">${v.title}</h3>
                    <span class="text-[10px] text-gray-400 font-bold uppercase tracking-tighter">${v.date}</span>
                </div>
            `;
            suggestionsList.appendChild(card);
        });

        // ─── Player: simula início de reprodução ─────────────────────────────────
        function startVideo() {
            document.getElementById('player-overlay').style.opacity = '0';
            setTimeout(() => {
                document.getElementById('player-overlay').classList.add('hidden');
                const active = document.getElementById('player-active');
                active.classList.remove('hidden');
                active.classList.add('flex');
            }, 300);
        }

        // ─── Botões de ação (toggle ativo/inativo) ───────────────────────────────
        function toggleAction(btn, type) {
            const isActive = btn.dataset.active === 'true';
            btn.dataset.active = isActive ? 'false' : 'true';
            btn.classList.toggle('text-[#D61F26]', !isActive);
            btn.classList.toggle('text-gray-400', isActive);
        }

        lucide.createIcons();
    </script>
</body>
</html>
