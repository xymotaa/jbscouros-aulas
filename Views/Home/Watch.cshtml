@model jbscouros_aulas.Models.WatchViewModel
@{
    Layout = "_LayoutJBS";
    ViewData["Title"] = Model.Video.Title + " – JBS Aulas";
}

<div class="max-w-5xl mx-auto px-4 md:px-8 py-8">

    <!-- Player de Vídeo -->
    <div id="player-container" class="relative w-full aspect-video bg-black rounded-sm overflow-hidden shadow-2xl mb-0">
        <img id="player-thumb"
             src="@Model.Video.ThumbnailUrl"
             alt="@Model.Video.Title"
             class="w-full h-full object-cover opacity-80" />

        <!-- Overlay com botão de play -->
        <div id="player-overlay"
             class="absolute inset-0 flex flex-col items-center justify-center bg-black/50 cursor-pointer"
             onclick="startVideo()">
            <div class="w-20 h-20 bg-[#1E6FD2] rounded-full flex items-center justify-center shadow-2xl hover:bg-[#1a5fb5] transition-colors mb-5">
                <i data-lucide="play" class="text-white fill-white w-9 h-9 ml-1"></i>
            </div>
            <span class="text-white text-[11px] font-black tracking-[0.3em] uppercase">Clique para iniciar</span>
        </div>
    </div>

    <!-- Informações do Vídeo -->
    <div class="bg-white border border-[#DDE3EC] border-t-0 rounded-b-sm px-6 py-6 mb-8">
        <div class="flex items-center gap-4 mb-4">
            <span class="bg-[#9EDB00] text-[#1A1A2E] text-[10px] font-black px-3 py-1 uppercase tracking-wider">
                @Model.Video.Category
            </span>
            @if (!string.IsNullOrEmpty(Model.Video.PublishDate))
            {
                <span class="text-[11px] font-bold text-gray-400 uppercase tracking-widest">@Model.Video.PublishDate</span>
            }
        </div>

        <h1 class="text-3xl md:text-4xl font-black text-[#1A1A2E] uppercase italic tracking-tighter leading-tight mb-4">
            @Model.Video.Title
        </h1>

        <p class="text-[#4A6080] text-sm leading-relaxed mb-6">
            @Model.Video.Description
        </p>
    </div>

    <!-- Sugestões de Vídeos -->
    @if (Model.Suggestions.Any())
    {
        <div class="mb-12">
            <div class="flex items-center gap-3 mb-1">
                <div class="w-1 h-6 bg-[#9EDB00]"></div>
                <h2 class="text-lg font-black text-[#1A1A2E] uppercase tracking-tighter italic">Sugestões</h2>
            </div>
            <div class="w-full h-[3px] bg-[#2E2F86] mb-6"></div>

            <div class="flex flex-col gap-4">
                @foreach (var suggestion in Model.Suggestions)
                {
                    <a href="@Url.Action("Watch", "Home", new { id = suggestion.Id })"
                       class="group flex gap-4 bg-white border border-[#DDE3EC] hover:border-[#1E6FD2] rounded-sm overflow-hidden shadow-sm hover:shadow-lg transition-all">

                        <!-- Thumbnail da sugestão -->
                        <div class="relative w-44 md:w-56 shrink-0 aspect-video overflow-hidden bg-gray-900">
                            <img src="@suggestion.ThumbnailUrl" alt="@suggestion.Title"
                                 class="w-full h-full object-cover opacity-90 group-hover:opacity-100 group-hover:scale-105 transition-all duration-500" />
                            <span class="absolute bottom-1.5 right-1.5 bg-[#1E6FD2] text-white px-1.5 py-0.5 rounded-sm text-[9px] font-black">
                                @suggestion.Duration
                            </span>
                            <div class="absolute inset-0 flex items-center justify-center opacity-0 group-hover:opacity-100 transition-opacity bg-black/40">
                                <div class="w-9 h-9 bg-[#1E6FD2] rounded-full flex items-center justify-center shadow-xl">
                                    <i data-lucide="play" class="text-white fill-white w-4 h-4 ml-0.5"></i>
                                </div>
                            </div>
                        </div>

                        <!-- Informações da sugestão -->
                        <div class="flex flex-col justify-center py-4 pr-4 gap-2">
                            <span class="text-[9px] font-black text-[#9EDB00] uppercase tracking-[0.2em]">@suggestion.Category</span>
                            <h3 class="font-bold text-sm text-[#1A1A2E] group-hover:text-[#1E6FD2] transition-colors uppercase tracking-tight leading-tight line-clamp-2">
                                @suggestion.Title
                            </h3>
                            @if (!string.IsNullOrEmpty(suggestion.PublishDate))
                            {
                                <span class="text-[10px] text-gray-400 font-bold uppercase tracking-tighter">@suggestion.PublishDate</span>
                            }
                        </div>

                    </a>
                }
            </div>
        </div>
    }

    <!-- Rodapé -->
    <footer class="py-10 border-t border-[#DDE3EC] flex flex-col md:flex-row justify-between items-center gap-6 text-[10px] font-bold text-gray-400 uppercase tracking-[0.3em]">
        <span>© 2025 JBS S.A. • Portal de Comunicação</span>
        <div class="flex gap-10">
            <a href="#" class="hover:text-[#1E6FD2] transition-colors">Suporte TI</a>
            <a href="#" class="hover:text-[#1E6FD2] transition-colors">Segurança</a>
        </div>
    </footer>

</div>

@section Scripts {
    <script>
        /**
         * Inicia a reprodução ocultando o overlay de thumbnail com transição suave.
         * O elemento #player-active pode ser adicionado futuramente para integrar
         * um player real (ex: iframe do YouTube ou tag <video>).
         */
        function startVideo() {
            const overlay = document.getElementById('player-overlay');
            overlay.style.opacity = '0';
            setTimeout(() => {
                overlay.classList.add('hidden');
                const active = document.getElementById('player-active');
                if (active) {
                    active.classList.remove('hidden');
                    active.classList.add('flex');
                }
            }, 300);
        }

        lucide.createIcons();
    </script>
}