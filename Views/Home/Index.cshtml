@model IEnumerable<jbscouros_aulas.Models.VideoViewModel>
@{
    Layout = "_LayoutJBS";
    ViewData["Title"] = "Tela Principal - JBS COUROS";

    // Categorias únicas extraídas do catálogo para a barra de filtros
    var categories = new[] { "Todos" }.Concat(Model.Select(v => v.Category).Distinct());
}

<!-- Barra de Filtros -->
<div class="bg-white border-b border-[#DDE3EC] px-8 py-4 flex items-center shadow-sm sticky top-0 z-10">
    <div class="flex items-center gap-2 text-[10px] font-black text-gray-400 uppercase tracking-widest shrink-0">
        <i data-lucide="filter" class="w-3 h-3"></i> FILTRAR:
    </div>
    <div class="flex justify-center flex-1">
        <div class="flex gap-2 overflow-x-auto no-scrollbar" id="category-filters">
            @foreach (var cat in categories)
            {
                var isActive = cat == "Todos";
                var btnClass = isActive
                    ? "px-6 py-2 rounded-sm text-[11px] font-bold whitespace-nowrap transition-all uppercase border bg-[#2E2F86] text-white border-[#2E2F86]"
                    : "px-6 py-2 rounded-sm text-[11px] font-bold whitespace-nowrap transition-all uppercase border bg-white text-gray-500 border-[#DDE3EC] hover:border-[#1E6FD2] hover:text-[#1E6FD2]";
                <button class="@btnClass" data-category="@cat" onclick="filterVideos(this)">@cat</button>
            }
        </div>
    </div>
</div>

<!-- Grade de Vídeos -->
<div class="px-8 py-12 max-w-7xl mx-auto">

    <div class="flex items-center gap-4 mb-10">
        <div class="w-1.5 h-8 bg-[#9EDB00]"></div>
        <h2 class="text-2xl font-black text-[#1A1A2E] uppercase tracking-tighter italic">Últimos Lançamentos</h2>
    </div>

    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-8" id="video-grid">
        @foreach (var video in Model)
        {
            <a href="@Url.Action("Watch", "Home", new { id = video.Id })"
               class="group flex flex-col bg-white rounded-sm overflow-hidden border border-[#DDE3EC] hover:border-[#1E6FD2] transition-all shadow-sm hover:shadow-xl"
               data-category="@video.Category">

                <!-- Thumbnail com overlay de play -->
                <div class="relative aspect-video overflow-hidden bg-gray-900">
                    <img src="@video.ThumbnailUrl" alt="@video.Title"
                         class="w-full h-full object-cover opacity-90 group-hover:opacity-100 transition-all duration-700 group-hover:scale-110" />
                    <span class="absolute bottom-2 right-2 bg-[#1E6FD2] text-white px-2 py-0.5 rounded-sm text-[9px] font-black">
                        @video.Duration
                    </span>
                    <div class="absolute inset-0 flex items-center justify-center opacity-0 group-hover:opacity-100 transition-opacity bg-black/40">
                        <div class="w-12 h-12 bg-[#1E6FD2] rounded-full flex items-center justify-center shadow-2xl transform scale-75 group-hover:scale-100 transition-transform">
                            <i data-lucide="play" class="text-white fill-white w-6 h-6 ml-1"></i>
                        </div>
                    </div>
                </div>

                <!-- Informações do card -->
                <div class="p-5 flex flex-col gap-3">
                    <span class="text-[9px] font-black text-[#9EDB00] uppercase tracking-[0.2em]">@video.Category</span>
                    <h3 class="font-bold text-[13px] text-[#1A1A2E] group-hover:text-[#1E6FD2] transition-colors line-clamp-2 leading-tight h-10 uppercase tracking-tight">
                        @video.Title
                    </h3>
                </div>

            </a>
        }
    </div>

    <!-- Banner de Sugestão -->
    <div class="mt-20 bg-[#2E2F86] p-10 rounded-sm flex flex-col md:flex-row items-center justify-between gap-8 border-l-[12px] border-[#46C1E6] shadow-xl">
        <div class="space-y-2">
            <h3 class="text-white font-black text-2xl uppercase italic tracking-tighter">Não encontrou o conteúdo?</h3>
            <p class="text-white/60 text-sm font-medium uppercase tracking-wider">Sugira novos treinamentos para o seu setor.</p>
        </div>
        <button class="bg-white text-[#2E2F86] px-10 py-4 rounded-sm font-black text-xs uppercase tracking-[0.2em] hover:bg-[#46C1E6] hover:text-white transition-all shadow-md">
            ENVIAR SUGESTÃO
        </button>
    </div>

    <!-- Rodapé -->
    <footer class="mt-24 py-12 border-t border-[#DDE3EC] flex flex-col md:flex-row justify-between items-center gap-6 text-[10px] font-bold text-gray-400 uppercase tracking-[0.3em]">
        <span>© 2025 JBS S.A. • Portal de Comunicação</span>
        <div class="flex gap-10">
            <a href="#" class="hover:text-[#1E6FD2] transition-colors">Suporte TI</a>
            <a href="#" class="hover:text-[#1E6FD2] transition-colors">Segurança</a>
        </div>
    </footer>

</div>

@section Scripts {
    <script>
        /**
         * Filtra os cards de vídeo pela categoria selecionada.
         * Atualiza o estado visual dos botões e exibe/oculta os cards correspondentes.
         * @@param {HTMLElement} btn - Botão de filtro clicado.
         */
        function filterVideos(btn) {
            const selected = btn.dataset.category;

            // Atualiza estado visual dos botões de filtro
            document.querySelectorAll('#category-filters button').forEach(b => {
                b.className = 'px-6 py-2 rounded-sm text-[11px] font-bold whitespace-nowrap transition-all uppercase border bg-white text-gray-500 border-[#DDE3EC] hover:border-[#1E6FD2] hover:text-[#1E6FD2]';
            });
            btn.className = 'px-6 py-2 rounded-sm text-[11px] font-bold whitespace-nowrap transition-all uppercase border bg-[#2E2F86] text-white border-[#2E2F86]';

            // Exibe ou oculta cards conforme a categoria selecionada
            document.querySelectorAll('#video-grid [data-category]').forEach(card => {
                const match = selected === 'Todos' || card.dataset.category === selected;
                card.style.display = match ? '' : 'none';
            });
        }

        lucide.createIcons();
    </script>
}